[Unit]
Description=Celery Beat for Baysoko
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
EnvironmentFile=/path/to/your/project/.env
WorkingDirectory=/path/to/your/project
ExecStart=/path/to/venv/bin/celery -A baysoko beat --loglevel=info
Restart=always

[Install]
WantedBy=multi-user.target
